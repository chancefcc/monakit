---
import { SITE_TITLE } from "@/consts";
import PageLayout from "@/layouts/PageLayout.astro";

const metadata = {
  title: `Products | ${SITE_TITLE}`,
  description:
    "The sovereign settlement layer for RWA Oracle Networks. AI-verified asset notarization, transparent token settlement, and regulatory-grade audit trails for energy, precious metals, and real-estate assets.",
};
---

<PageLayout> title={metadata.title} description={metadata.description}>
  <div class="w-full px-4 md:px-6 py-16">
    <!-- Hero Section -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-teahouse-dark mb-6">
          The Sovereign Settlement Layer for Real World Assets
        </h1>
        <p class="text-xl leading-relaxed text-teahouse-text-secondary mb-10">
          AI-verified asset notarization, transparent token settlement, and regulatory-grade audit trails for the RWA ecosystem. Energy, precious metals, real-estate, and more.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#investors"
            class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-teahouse-primary hover:bg-teahouse-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            For Investors & Stakeholders
          </a>
          <a
            href="#institutions"
            class="inline-flex items-center justify-center px-6 py-3 border border-teahouse-border text-base font-medium rounded-md text-teahouse-text bg-teahouse-bg hover:bg-teahouse-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            For Financial Institutions
          </a>
          <a
            href="#regulators"
            class="inline-flex items-center justify-center px-6 py-3 border border-teahouse-border text-base font-medium rounded-md text-teahouse-text bg-teahouse-bg hover:bg-teahouse-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            For Regulators
          </a>
        </div>
      </div>
    </div>

    <!-- Technical Architecture Overview -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="bg-gradient-to-r from-teahouse-primary/10 to-teahouse-primary/5 rounded-xl p-8 md:p-12 border border-teahouse-border">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-teahouse-dark mb-4">Built on Trust, Verified by AI, Secured by Design</h2>
          <p class="text-lg text-teahouse-text-secondary mb-8">
            Our Clearing & Settlement House leverages Micro Services, embedded EVM Bridge, and oracle-validated telemetry to provide the most secure and transparent RWA settlement infrastructure.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-teahouse-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-teahouse-dark mb-2">AI-Verified Notarization</h3>
            <p class="text-sm text-teahouse-text-secondary">Oracle-validated external telemetry with n8n workflow automation</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-teahouse-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-teahouse-dark mb-2">Instant Settlement</h3>
            <p class="text-sm text-teahouse-text-secondary">Atomic $TIK burn → $TAG mint transactions via EVM Bridge</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-teahouse-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-teahouse-dark mb-2">Immutable Audit Trails</h3>
            <p class="text-sm text-teahouse-text-secondary">JetStream streams with complete transaction history and cold archival</p>
          </div>
        </div>
      </div>
    </div>

    <!-- For Investors Section -->
    <div id="investors" class="max-w-7xl mx-auto mb-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-medium mb-4">
          WALLET USERS ON TIKOLY.COM
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-teahouse-dark mb-4">For Investors & Stakeholders</h2>
        <p class="text-lg leading-relaxed text-teahouse-text-secondary">
          Trade RWA assets with confidence through Tikoly.com. Every asset is AI-notarized, every settlement is transparent, and your portfolio is protected by the Settlement Graph.
        </p>
      </div>

      <!-- Value Propositions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">AI-Verified Asset Integrity</h3>
          <p class="text-teahouse-text-secondary mb-4">
            All assets undergo oracle-verified notarization before tokenization. Energy systems validated against NREL data, precious metals via supply chain records, real-estate through property registries.
          </p>
          <ul class="text-sm text-teahouse-text-secondary space-y-2">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              External telemetry validation
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Cryptographic asset proofs
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Peer validation network
            </li>
          </ul>
        </div>

        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">Transparent Settlement Records</h3>
          <p class="text-teahouse-text-secondary mb-4">
            Every $TIK burn and $TAG mint transaction is immutably recorded. Access complete audit trails through your wallet and verify settlement status in real-time.
          </p>
          <ul class="text-sm text-teahouse-text-secondary space-y-2">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Real-time audit trails
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              SettlementAudit stream access
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Geth transaction hashes
            </li>
          </ul>
        </div>

        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">Settlement Graph Trust Network</h3>
          <p class="text-teahouse-text-secondary mb-4">
            Follow trusted nodes to filter asset provenance. Leverage peer validation and decentralized reputation to make informed investment decisions.
          </p>
          <ul class="text-sm text-teahouse-text-secondary space-y-2">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              P2P trust relationships
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Decentralized reputation
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Community-driven validation
            </li>
          </ul>
        </div>
      </div>

      <!-- How It Works -->
      <div class="max-w-4xl mx-auto">
        <h3 class="text-3xl font-bold text-teahouse-dark text-center mb-12">How Trading Works on Tikoly.com</h3>
        <div class="space-y-8">
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-teahouse-primary flex items-center justify-center text-white font-bold text-lg">1</div>
            <div class="flex-1">
              <h4 class="text-xl font-semibold text-teahouse-dark mb-2">Connect Your Wallet</h4>
              <p class="text-teahouse-text-secondary">
                Link your Logto-authenticated wallet to Tikoly.com. Secure, seamless, and ready for RWA trading with $TIK and $TAG tokens.
              </p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-teahouse-primary flex items-center justify-center text-white font-bold text-lg">2</div>
            <div class="flex-1">
              <h4 class="text-xl font-semibold text-teahouse-dark mb-2">Browse Verified Assets</h4>
              <p class="text-teahouse-text-secondary">
                Explore AI-notarized RWA assets across energy systems, precious metals, and real-estate. Each asset comes with complete audit trails, settlement graph trust scores, and oracle-verified telemetry.
              </p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-teahouse-primary flex items-center justify-center text-white font-bold text-lg">3</div>
            <div class="flex-1">
              <h4 class="text-xl font-semibold text-teahouse-dark mb-2">Execute Settlement</h4>
              <p class="text-teahouse-text-secondary">
                Instant atomic settlement with $TIK burn → $TAG mint transactions. All settlements are recorded on the SettlementAudit stream with Geth transaction hashes for complete transparency.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Supported Asset Types -->
      <div class="mt-16 max-w-5xl mx-auto">
        <h3 class="text-2xl font-bold text-teahouse-dark text-center mb-8">Supported Asset Classes</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-lg p-6 border border-yellow-200">
            <div class="text-3xl mb-3">⚡</div>
            <h4 class="font-semibold text-gray-900 mb-2">Energy Systems</h4>
            <p class="text-sm text-gray-800">Solar arrays, wind farms, battery storage with NREL telemetry validation</p>
          </div>
          <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-6 border border-gray-200">
            <div class="text-3xl mb-3">🥇</div>
            <h4 class="font-semibold text-gray-900 mb-2">Precious Metals</h4>
            <p class="text-sm text-gray-800">Gold, silver, platinum with supply chain provenance and assay certificates</p>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-6 border border-blue-200">
            <div class="text-3xl mb-3">🏠</div>
            <h4 class="font-semibold text-gray-900 mb-2">Real Estate</h4>
            <p class="text-sm text-gray-800">Commercial and residential properties with registry verification and IoT monitoring</p>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-teahouse-border my-20"></div>

    <!-- For Financial Institutions Section -->
    <div id="institutions" class="max-w-7xl mx-auto mb-24">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium mb-4">
          ASSET AUDITING & TRADING
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-teahouse-dark mb-4">For Financial Institutions</h2>
        <p class="text-lg leading-relaxed text-teahouse-text-secondary">
          Enterprise-grade settlement infrastructure for RWA trading and asset auditing. Programmatic API access, automated settlement, and compliance-ready audit trails.
        </p>
      </div>

      <!-- Core Products Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md overflow-hidden border border-teahouse-border">
          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="text-xl font-bold text-teahouse-dark">Micro Services API</h3>
                <div class="text-sm text-teahouse-text-secondary">Programmatic Settlement Layer</div>
              </div>
              <div class="bg-teahouse-primary text-white px-3 py-1 rounded-full text-xs font-medium">Core</div>
            </div>
            <p class="text-teahouse-text-secondary mb-4">
              Access asset notarization and settlement operations via RESTful endpoints. Integrate seamlessly with your existing trading systems.
            </p>
            <div class="bg-teahouse-bg rounded-lg p-4 mb-4">
              <code class="text-xs text-teahouse-dark font-mono">
                $SRV.SETTLE.PROVE → Asset Notarization<br>
                $SRV.SETTLE.LIST → Registry Query<br>
                $SRV.LEDGER.SYNC → Balance Sync
              </code>
            </div>
            <ul class="text-sm text-teahouse-text-secondary space-y-2 mb-4">
              <li class="flex items-start">
                <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                Asset Notarization workflow
              </li>
              <li class="flex items-start">
                <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                Automated settlement execution
              </li>
              <li class="flex items-start">
                <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                SBAC security at server level
              </li>
            </ul>
          </div>
        </div>

        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md overflow-hidden border border-teahouse-border">
          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="text-xl font-bold text-teahouse-dark">Enterprise Dashboard</h3>
                <div class="text-sm text-teahouse-text-secondary">Management Interface</div>
              </div>
              <div class="bg-teahouse-primary text-white px-3 py-1 rounded-full text-xs font-medium">Core</div>
            </div>
            <p class="text-teahouse-text-secondary mb-4">
              Comprehensive management interface for asset listing, monitoring, and settlement operations. Real-time sync with ledger and workflow automation.
            </p>
            <div class="bg-teahouse-bg rounded-lg p-4 mb-4">
              <code class="text-xs text-teahouse-dark font-mono">
                Asset Listing → Notarization → Settlement → Audit
              </code>
            </div>
            <ul class="text-sm text-teahouse-text-secondary space-y-2 mb-4">
              <li class="flex items-start">
                <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                Real-time ledger sync
              </li>
              <li class="flex items-start">
                <svg class="h-4 w-4 text-teahouse-primary mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
