        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md overflow-hidden border border-teahouse-border">
          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="text-xl font-bold text-teahouse-dark">n8n Workflow Bridge</h3>
                <div class="text-sm text-teahouse-text-secondary">Validation Automation</div>
              </div>
