---
import { FEATURES } from "@consts";
import BottomLayout from "@layouts/BottomLayout.astro";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";

const features = [
  {
    title: "Agentic SDK",
    icon: "code",
    description:
      "Go-based SDK for NATS-based wallet signature triggers. Build autonomous agents that can transact seamlessly.",
    details:
      "Full NATS Micro service integration with Protobuf schemas. Easy-to-use client libraries for agent-to-settlement communication.",
  },
  {
    title: "Privacy-First Architecture",
    icon: "shield",
    description:
      "ZK-proofs from Tikoly keep merchant data private while ensuring the agent gets paid.",
    details:
      "Zero-knowledge proof verification with Polygon ID. No sensitive merchant data is ever exposed on-chain.",
  },
  {
    title: "TigerBeetle Performance",
    icon: "zap",
    description:
      "1,000,000+ TPS capability for micro-settlements with sub-millisecond latency.",
    details:
      "Financial-grade double-entry accounting. Optimized for high-frequency agentic transactions.",
  },
  {
    title: "Open Source Heritage",
    icon: "github",
    description:
      "Community-driven Taho fork providing a non-custodial alternative to proprietary wallets.",
    details:
      "Fully auditable codebase. MIT-licensed for maximum transparency. Community governance through GitHub.",
  },
  {
    title: "X Layer Integration",
    icon: "stack",
    description:
      "Native OKB gas support on X Layer for ultra-low fees and deep regional liquidity.",
    details:
      "Seamless cross-chain settlements. Optimized for ASEAN commerce and DePIN applications.",
  },
  {
    title: "Settlement Graph",
    icon: "network",
    description:
      "P2P trust network where nodes vouch for the validity of asset data.",
    details:
      "Decentralized reputation system. Follow/unfollow mechanisms for establishing mutual settlement trust.",
  },
];
---

<PageLayout title={FEATURES.TITLE} description={FEATURES.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      Core Features
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="space-y-12">
      {features.map((feature, index) => (
        <li class={`animate border-b border-black/10 dark:border-white/25 py-8 ${index === 0 ? 'first-of-type:mt-0 first-of-type:pt-0' : ''} ${index === features.length - 1 ? 'last-of-type:border-none' : ''}`}>
          <div class="grid md:grid-cols-3 gap-8">
            <div class="md:col-span-1">
              <div class="w-16 h-16 bg-blue-500/10 dark:bg-blue-500/20 rounded-2xl flex items-center justify-center text-blue-500 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {feature.icon === "code" && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                  {feature.icon === "shield" && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></>}
                  {feature.icon === "zap" && <><path d="M4 14.71 13.18 3l-1.35 7.71h7.45l-9.18 11.71 1.35-7.71H4Z"/></>}
                  {feature.icon === "github" && <><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></>}
                  {feature.icon === "stack" && <><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></>}
                  {feature.icon === "network" && <><circle cx="12" cy="12" r="3"/><path d="M12 21v-6"/><path d="M12 3v6"/><path d="M3 12h6"/><path d="M15 12h6"/><path d="M7 7l4 4"/><path d="M13 13l4 4"/><path d="M7 17l4-4"/><path d="M13 11l4-4"/></>}
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-black dark:text-white">
                {feature.title}
              </h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-base text-black dark:text-white mb-4">
                {feature.description}
              </p>
              <p class="text-sm opacity-75 leading-relaxed">
                {feature.details}
              </p>
            </div>
          </div>
        </li>
      ))}
    </div>
  </BottomLayout>
</PageLayout>
