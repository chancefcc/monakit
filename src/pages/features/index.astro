---
import { FEATURES } from "@consts";
import BottomLayout from "@layouts/BottomLayout.astro";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";

const features = [
  {
    title: "Sovereign Agent Identity",
    icon: "shield",
    description:
      "Every agent gets a cryptographically verifiable identity using NATS Nkey/JWT authentication. Decentralized identity management ensures agents can authenticate and authorize without any central authority.",
    details:
      "Nkey-based Ed25519 key pairs provide strong cryptographic identity. JWT authentication enables scoped, time-limited authorization. Agents can prove their identity to any other agent in the network without relying on a third party.",
  },
  {
    title: "P2P Trust Network",
    icon: "network",
    description:
      "Agents establish peer-to-peer trust relationships through verifiable credentials and decentralized reputation scoring. Build a trust graph that enables autonomous collaboration.",
    details:
      "Trust is established through verifiable credential exchange and attestation. Reputation scoring provides a quantitative measure of agent reliability. The trust graph evolves organically as agents interact and vouch for each other.",
  },
  {
    title: "TigerBeetle High-Performance Ledger",
    icon: "zap",
    description:
      "Financial-grade double-entry accounting engine capable of 100,000+ transactions per second. Built for the demanding requirements of autonomous agent settlement and resource accounting.",
    details:
      "TigerBeetle provides sub-millisecond latency with deterministic accounting guarantees. Each transaction is cryptographically verified and auditable. The ledger supports complex multi-agent settlement scenarios with full integrity guarantees.",
  },
  {
    title: "Temporal Workflow Orchestration",
    icon: "code",
    description:
      "Reliable, durable workflow execution for multi-step agent protocols. Temporal ensures that complex agent interactions complete successfully, even in the face of failures.",
    details:
      "Temporal provides durable execution with automatic retries, timeouts, and state persistence. Complex multi-agent workflows can be modeled as simple code. Workflow history provides complete audit trails for all agent interactions.",
  },
  {
    title: "VGate Agent Management API",
    icon: "stack",
    description:
      "Comprehensive API for agent lifecycle management, identity issuance, and policy enforcement. The VGate orchestrator provides a unified control plane for all agents in your ecosystem.",
    details:
      "RESTful and NATS-based APIs for agent registration, authentication, and authorization. Policy-based access control with fine-grained permissions. Real-time monitoring and management of agent activity across the network.",
  },
  {
    title: "One-Click Agent Templates",
    icon: "github",
    description:
      "Pre-built agent templates for common use cases. Deploy agents for identity verification, settlement processing, trust scoring, and more with a single command.",
    details:
      "Templates include pre-configured NATS subjects, TigerBeetle account schemas, and Temporal workflow definitions. Customizable for specific business logic. Open-source and community-contributed templates available on GitHub.",
  },
];
---

<PageLayout title={FEATURES.TITLE} description={FEATURES.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      Core Features
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="space-y-12">
      {features.map((feature, index) => (
        <div class={`animate border-b border-black/10 dark:border-white/25 py-8 ${index === 0 ? 'first-of-type:mt-0 first-of-type:pt-0' : ''} ${index === features.length - 1 ? 'last-of-type:border-none' : ''}`}>
          <div class="grid md:grid-cols-3 gap-8">
            <div class="md:col-span-1">
              <div class="w-16 h-16 bg-blue-500/10 dark:bg-blue-500/20 rounded-2xl flex items-center justify-center text-blue-500 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {feature.icon === "code" && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                  {feature.icon === "shield" && <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
                  {feature.icon === "zap" && <><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></>}
                  {feature.icon === "github" && <><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></>}
                  {feature.icon === "stack" && <><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></>}
                  {feature.icon === "network" && <><circle cx="12" cy="12" r="3"/><path d="M12 21v-6"/><path d="M12 3v6"/><path d="M3 12h6"/><path d="M15 12h6"/><path d="M7 7l4 4"/><path d="M13 13l4 4"/><path d="M7 17l4-4"/><path d="M13 11l4-4"/></>}
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-black dark:text-white">
                {feature.title}
              </h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-base text-black dark:text-white mb-4">
                {feature.description}
              </p>
              <p class="text-sm opacity-75 leading-relaxed">
                {feature.details}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </BottomLayout>
</PageLayout>
