---
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import MainLayout from "@/layouts/MainLayout.astro";

const metadata = {
  title: `About | ${SITE_TITLE}`,
  description: "The sovereign settlement layer for RWA Oracle Networks. AI-verified asset notarization, transparent token settlement, and regulatory-grade audit trails for energy, precious metals, and real-estate assets.",
};
---

<MainLayout title={metadata.title} description={metadata.description}>
  <div class="w-full px-4 md:px-6 py-16">
    <!-- Hero Section -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-teahouse-primary/10 text-teahouse-primary text-sm font-medium mb-6">
          <span class="mr-2">🏝️</span> Operating in Virgin Islands Jurisdiction
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-teahouse-dark mb-6">
          The Sovereign Settlement Layer for Real World Assets
        </h1>
        <p class="text-xl leading-relaxed text-teahouse-text-secondary max-w-3xl mx-auto">
          AI-verified asset notarization, transparent token settlement, and regulatory-grade audit trails for energy, precious metals, and real-estate assets operating in Virgin Islands jurisdiction.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a
            href="#mission"
            class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-teahouse-primary hover:bg-teahouse-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            Our Mission
          </a>
          <a
            href="/products"
            class="inline-flex items-center justify-center px-6 py-3 border border-teahouse-border text-base font-medium rounded-md text-teahouse-text bg-teahouse-bg hover:bg-teahouse-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            Products
          </a>
          <a
            href="https://github.com/tiktagapp/tiktag-cli"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 border border-teahouse-border text-base font-medium rounded-md text-teahouse-text bg-teahouse-bg hover:bg-teahouse-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            GitHub Repository
          </a>
        </div>
      </div>
    </div>

    <!-- Mission Section -->
    <div id="mission" class="max-w-7xl mx-auto mb-20">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-teahouse-dark mb-4">Our Mission</h2>
        <p class="text-lg leading-relaxed text-teahouse-text-secondary max-w-3xl mx-auto">
          To establish a Clearing & Settlement House for RWA Oracle Networks that provides the most secure, transparent, and regulatory-grade infrastructure for tokenizing and trading real world assets on-chain.
        </p>
      </div>

      <!-- Core Value Propositions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">AI-Verified Asset Notarization</h3>
          <p class="text-teahouse-text-secondary">
            Every asset undergoes oracle-validated notarization via external telemetry data (NREL for energy, supply chain records for metals, property registries for real estate) before being tokenized.
          </p>
          <p class="text-sm text-teahouse-text-secondary mt-4">
            <span class="font-semibold text-teahouse-dark">Key Benefit:</span> Cryptographic asset proofs with Merkle root hashes stored in immutable settlement registry.
          </p>
        </div>

        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">Atomic Token Settlement</h3>
          <p class="text-teahouse-text-secondary">
            Settlement transactions execute atomic $TIK burn → $TAG mint operations via our embedded EVM Bridge, ensuring instant finality and complete transparency with on-chain transaction records.
          </p>
          <p class="text-sm text-teahouse-text-secondary mt-4">
            <span class="font-semibold text-teahouse-dark">Key Benefit:</span> JetStream audit streams provide complete settlement history and cold data archival for long-term regulatory compliance.
          </p>
        </div>

        <div class="bg-teahouse-bg-secondary rounded-lg shadow-md p-6 border border-teahouse-border">
          <div class="w-12 h-12 rounded-lg bg-teahouse-primary/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teahouse-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012 2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-teahouse-dark mb-2">Regulatory-Grade Audit Trails</h3>
          <p class="text-teahouse-text-secondary">
            All settlement events are published to JetStream streams with cryptographic proofs and timestamps, creating an immutable audit trail for regulatory supervision and compliance verification.
          </p>
          <p class="text-sm text-teahouse-text-secondary mt-4">
            <span class="font-semibold text-teahouse-dark">Key Benefit:</span> Subject-Based Access Control (SBAC) enforced at the server level via Logto OIDC authentication and NKey mapping.
          </p>
        </div>
      </div>
    </div>

    <!-- Technical Architecture Section -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="bg-gradient-to-r from-teahouse-primary/10 to-teahouse-primary/5 rounded-xl p-8 md:p-12 border border-teahouse-border">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-teahouse-dark mb-4">Built on Trust, Verified by AI, Secured by Design</h2>
          <p class="text-lg text-teahouse-text-secondary mb-8">
            Our Clearing & Settlement House leverages NATS Micro Services, embedded EVM Bridge, n8n Workflow Automation, and oracle-validated telemetry to provide the most secure and transparent RWA settlement infrastructure.
          </p>
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="max-w-4xl mx-auto bg-teahouse-primary/5 rounded-xl p-8 border border-teahouse-border">
      <div class="text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Explore Tiktag Solutions</h2>
        <p class="text-teahouse-text-secondary mb-6">
          Discover our sovereign settlement infrastructure and services for the RWA Oracle Networks ecosystem.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/products"
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-teahouse-primary hover:bg-teahouse-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teahouse-primary transition-colors"
          >
            Tiktag Products
          </a>
          <a
            href="/slides"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-base font-medium rounded-md text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white transition-colors"
          >
            Case Study
          </a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
