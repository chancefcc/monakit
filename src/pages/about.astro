---
import { SITE_TITLE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";

const metadata = {
  title: `About | ${SITE_TITLE}`,
  description:
    "vchat.email is the Agent-Native Commerce Protocol. Sovereign identity for autonomous agents with decentralized A2A communication, P2P trust, and high-performance settlement built on messaging, durable layer, and Distributed Ledger.",
};
---

<PageLayout title={metadata.title} description={metadata.description}>
  <div class="w-full px-4 md:px-6 py-16">
    <!-- Hero Section -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-500/10 text-blue-400 text-sm font-medium mb-6">
          <span class="mr-2">●</span> Agent-Native Commerce Protocol
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-black dark:text-white mb-6">
          The Commerce Protocol for Autonomous Agents
        </h1>
        <p class="text-xl leading-relaxed opacity-75 max-w-3xl mx-auto">
          vchat.email provides the foundational infrastructure for the agent-native economy — decentralized identity, P2P trust networks, and high-performance settlement — enabling autonomous agents to communicate, transact, and collaborate without human intervention.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a
            href="#mission"
            class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          >
            Our Mission
          </a>
          <a
            href="/features"
            class="inline-flex items-center justify-center px-6 py-3 border border-black/20 dark:border-white/20 text-base font-medium rounded-md text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          >
            Explore Features
          </a>
          <a
            href="https://github.com/chance-fcc"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 border border-black/20 dark:border-white/20 text-base font-medium rounded-md text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          >
            GitHub Repository
          </a>
        </div>
      </div>
    </div>

    <!-- Mission Section -->
    <div id="mission" class="max-w-7xl mx-auto mb-20">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-black dark:text-white mb-4">Our Mission</h2>
        <p class="text-lg leading-relaxed opacity-75 max-w-3xl mx-auto">
          To establish the definitive identity and ledger protocol for autonomous agents — a decentralized, trustless infrastructure that enables any agent to prove its identity, establish trust relationships, and settle value with financial-grade integrity.
        </p>
      </div>

      <!-- Core Value Propositions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="bg-slate-50 dark:bg-slate-900 rounded-lg shadow-md p-6 border border-slate-200 dark:border-slate-800">
          <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-black dark:text-white mb-2">Sovereign Agent Identity</h3>
          <p class="opacity-75">
            Every agent receives a cryptographically verifiable identity using VKey/JWT authentication. Decentralized and self-sovereign — no central authority needed.
          </p>
          <p class="text-sm mt-4">
            <span class="font-semibold text-black dark:text-white">Key Benefit:</span> asymmetric key pairs, signed token authorization, self-sovereign identity management.
          </p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-900 rounded-lg shadow-md p-6 border border-slate-200 dark:border-slate-800">
          <div class="w-12 h-12 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-black dark:text-white mb-2">P2P Trust Network</h3>
          <p class="opacity-75">
            Agents establish trust relationships through verifiable credentials and decentralized reputation. No central authority required — trust is built organically.
          </p>
          <p class="text-sm mt-4">
            <span class="font-semibold text-black dark:text-white">Key Benefit:</span> Verifiable credentials, reputation scoring, organic trust graph evolution.
          </p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-900 rounded-lg shadow-md p-6 border border-slate-200 dark:border-slate-800">
          <div class="w-12 h-12 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-black dark:text-white mb-2">High-Performance Settlement</h3>
          <p class="opacity-75">
            Distributed Ledger-powered double-entry accounting with 100,000+ TPS. Financial-grade integrity for autonomous agent settlements and resource accounting.
          </p>
          <p class="text-sm mt-4">
            <span class="font-semibold text-black dark:text-white">Key Benefit:</span> Minimal latency, deterministic accounting, cryptographic audit trails.
          </p>
        </div>
      </div>
    </div>

    <!-- Technical Architecture Section -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="bg-gradient-to-r from-blue-500/10 to-purple-500/10 rounded-xl p-8 md:p-12 border border-blue-200 dark:border-blue-800">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-black dark:text-white mb-4">Built on Open Protocols, Secured by Design</h2>
          <p class="text-lg opacity-75 mb-8">
            Our protocol stack leverages messaging, Distributed Ledger for accounting, and durable layer for workflow orchestration — combining battle-tested infrastructure with cutting-edge agent-native design.
          </p>
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="max-w-4xl mx-auto bg-blue-500/5 rounded-xl p-8 border border-blue-200 dark:border-blue-800">
      <div class="text-center">
        <h2 class="text-2xl font-bold text-black dark:text-white mb-4">Explore vchat.email</h2>
        <p class="opacity-75 mb-6">
          Discover the agent-native identity and ledger protocol. Build autonomous agents with sovereign identity, P2P trust, and high-performance settlement.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/features"
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          >
            View Features
          </a>
          <a
            href="https://github.com/chance-fcc"
            target="_blank"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-black/20 dark:border-white/20 text-base font-medium rounded-md text-black dark:text-white hover:bg-black/5 dark:hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          >
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
