---
import { type CollectionEntry, getCollection } from "astro:content";
import Search from "@components/Search";
import { SEARCH } from "@consts";
import BottomLayout from "@layouts/BottomLayout.astro";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";

const posts = (await getCollection("blog")).filter((post) => !post.data.draft).map(({ body, rendered, ...rest }) => rest);

let sdk: any[] = [];
try {
  sdk = (await getCollection("sdk")).filter((post) => !post.data.draft).map(({ body, rendered, ...rest }) => rest);
} catch (e) {
  // SDK collection may not exist or be empty
}

const data = [...posts, ...sdk] as any[];
---

<PageLayout title={SEARCH.TITLE} description={SEARCH.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      {SEARCH.TITLE}
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <Search client:load data={data} />
    </div>
  </BottomLayout>
</PageLayout>
