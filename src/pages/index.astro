---
import MeteorShower from "@components/MeteorShower.astro";
import StackCard from "@components/StackCard.astro";
import TwinklingStars from "@components/TwinklingStars.astro";
import { SITE, SOCIALS } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";

const stack = [
  {
    text: "X Layer",
    icon: "stack",
    href: "https://www.okx.com/web3/x-layer",
  },
  {
    text: "Taho",
    icon: "brand",
    href: "https://tahowallet.app",
  },
  {
    text: "Polygon ID",
    icon: "stack",
    href: "https://polygon.technology/identity",
  },
];
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <script is:inline src="/js/bg.js"></script>

  <!-- Light Mode: Particles -->
  <div class='absolute inset-0 block dark:hidden'>
    <div id='particles1' class='fixed inset-0'></div>
    <div id='particles2' class='fixed inset-0'></div>
    <div id='particles3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class='absolute inset-0 bg-black hidden dark:block'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>
  
  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div id="planetcont" class='animate absolute inset-0 top-1/4 overflow-hidden'>
      <div id="crescent" class='absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-[100vh] aspect-square rounded-full p-[1px] bg-gradient-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%'>
        <div id="planet" class='w-full h-full bg-white dark:bg-black rounded-full p-[1px] overflow-hidden flex justify-center'>
          <div id="blur" class='w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl'/>
        </div>
      </div>
    </div>
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class='relative w-full h-full flex items-center justify-center'>
        <div class='p-5 text-center max-w-4xl'>
          <div class='animated inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full border border-blue-500/20 bg-blue-500/5 text-blue-400 text-xs font-mono uppercase tracking-widest'>
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            Powered by X Layer AggLayer
          </div>
          <h1 class='animated text-5xl md:text-7xl font-extrabold tracking-tight leading-tight mb-6'>
            Settlement for <br/>
            <span class="bg-gradient-to-r from-green-400 via-[#73c732] to-green-600 text-transparent bg-clip-text">
              Agentic Commerce
            </span>
          </h1>
          <p class='animated text-lg md:text-xl opacity-75 mb-8 max-w-2xl mx-auto'>
            The real-world asset wallet designed for autonomous agents. 
            Instant, private, and high-integrity settlement for the DePIN economy.
          </p>
          <div id="ctaButtons" class='animated flex flex-col md:flex-row items-center justify-center gap-4'>
            <a href='/features' class='py-3 px-8 bg-white dark:bg-slate-900 text-black dark:text-white font-bold rounded-2xl hover:opacity-90 transition text-center'>
              Explore Features
            </a>
            <a href='https://github.com/tiktagapp' target='_blank' class='py-3 px-8 border border-black/25 dark:border-white/25 font-bold rounded-2xl hover:bg-black/5 dark:hover:bg-white/15 transition text-center'>
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-xl p-5 space-y-24 pb-16">

      <!-- Core Features Section -->
      <section class="animate">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-black dark:text-white">
            Built for the Agentic Economy
          </h2>
          <p class="text-lg opacity-75 max-w-2xl mx-auto">
            Tiktag combines zero-knowledge proofs, high-performance ledger, and open-source & auditable wallet.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Feature 1: ZK-Verified Proofs -->
          <div class="p-8 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl space-y-4 hover:border-blue-500/50 transition">
            <div class="w-12 h-12 bg-blue-500/10 dark:bg-blue-500/20 rounded-2xl flex items-center justify-center text-blue-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black dark:text-white">ZK-Verified Proofs</h3>
            <p class="text-sm opacity-75 leading-relaxed">
              Integrates with Tikoly.com to verify data-driven operational proofs before every settlement. Privacy-first design keeps merchant data secure.
            </p>
          </div>

          <!-- Feature 2: Shadow Ledger -->
          <div class="p-8 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl space-y-4 hover:border-purple-500/50 transition">
            <div class="w-12 h-12 bg-purple-500/10 dark:bg-purple-500/20 rounded-2xl flex items-center justify-center text-purple-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 14.71 13.18 3l-1.35 7.71h7.45l-9.18 11.71 1.35-7.71H4Z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black dark:text-white">Shadow Ledger</h3>
            <p class="text-sm opacity-75 leading-relaxed">
              Powered by high-performant ledger tech for sub-millisecond double-entry accounting and financial-grade integrity. Capable of 1,000,000+ TPS for micro-settlements.
            </p>
          </div>

          <!-- Feature 3: ASEAN Settlement -->
          <div class="p-8 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl space-y-4 hover:border-green-500/50 transition">
            <div class="w-12 h-12 bg-green-500/10 dark:bg-green-500/20 rounded-2xl flex items-center justify-center text-green-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/>
                <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/>
                <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black dark:text-white">ASEAN Settlement</h3>
            <p class="text-sm opacity-75 leading-relaxed">
              Native OKB gas support on X Layer for ultra-low fees and deep regional liquidity. Optimized for Southeast Asian commerce.
            </p>
          </div>
        </div>
      </section>

      <!-- Tech Stack Banner -->
      <section class="animate py-12 bg-slate-50 dark:bg-slate-900/50 border-y border-slate-200 dark:border-slate-800">
        <div class="text-center">
          <p class="text-xs font-mono uppercase tracking-[0.3em] opacity-50 mb-8">
            Integrated With The Best
          </p>
          <div class="flex flex-wrap justify-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
            <span class="font-bold text-2xl text-black dark:text-white">X LAYER</span>
            <span class="font-bold text-2xl text-black dark:text-white">TAHO</span>
            <span class="font-bold text-2xl text-black dark:text-white">POLYGON ID</span>
          </div>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            Built with
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard 
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <p class="text-sm opacity-75">
            A Taho fork combining the best of open-source wallets with enterprise-grade infrastructure.
          </p>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            Get Started
          </p>
          <p class="mb-4">
            Join the agentic commerce revolution. Connect with us on GitHub, Twitter, or email.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate text-black dark:text-white">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>

  <footer class="py-12 px-6 text-center text-slate-500 dark:text-slate-400 text-sm border-t border-slate-200 dark:border-slate-800">
    <p>&copy; 2026 Tiktag.app - Built for the Agentic Economy.</p>
  </footer>
</PageLayout>
