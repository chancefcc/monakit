---
import { Image } from "astro:assets";
import OptimizedImage from "@/components/OptimizedImage.astro";
import logo from "@/assets/images/logo.webp";
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-sm text-slate-500">
        <Image
          src={logo}
          alt="tiktag"
          width={120}
          height={40}
          class="h-6 w-auto"
        />
        <span>© 2025 tiktag. All rights reserved.</span>
      </div>

      <div class="flex items-center gap-3">
        <form
          action="https://app.convertkit.com/forms/6606511/subscriptions"
          method="post"
          class="flex items-center gap-2"
        >
          <label for="email" class="sr-only">Email address</label>
          <input
            type="email"
            id="email"
            name="email_address"
            placeholder="Enter your email"
            required
            class="w-[200px] px-3 py-2 rounded-md border border-slate-700 bg-slate-900 text-white placeholder:text-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
          />
          <button
            type="submit"
            class="px-3 py-2 text-white rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-950 text-sm"
            style="background-color: #73c732;"
          >
            Subscribe
          </button>
        </form>
        <span aria-hidden="true" class="text-slate-700">|</span>
        <a
          href='/rss.xml'
          target="_blank"
          class="text-slate-500 transition-colors hover:text-emerald-400"
        >
          <OptimizedImage
            src="/rss.svg"
            alt="RSS"
            width={20}
            height={20}
            class="w-5 h-5 invert"
          />
        </a>
      </div>
    </div>
  </div>
</footer>
