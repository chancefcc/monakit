{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@types": ["src/types"],
      "@lib/*": ["src/lib/*"],
      "@consts": ["src/consts.ts"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strictNullChecks": true,
    "types": ["astro/client", "solid-js", "solid-js/web"]
  },
  "exclude": ["dist/", "public/"]
}
